{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "JS-Confuser",
  "colors": {
    "primary": "#3399ff",
    "light": "#3399ff",
    "dark": "#3399ff"
  },
  "favicon": {
    "light": "/images/apple-touch-icon.png",
    "dark": "/images/apple-touch-icon.png"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart"]
      }
    ],
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "getting-started/what-is-obfuscation",
          "getting-started/playground",
          "getting-started/installation",
          "getting-started/usage",
          "getting-started/faq",
          "getting-started/best-practices",
          "getting-started/roadmap"
        ]
      },
      {
        "group": "Options",
        "pages": [
          "options",
          {
            "group": "Build Settings",
            "pages": ["options/target", "options/sourceMap", "options/pack"]
          },
          {
            "group": "Identifiers",
            "pages": [
              "options/identifierGenerator",
              "options/renameVariables",
              "options/renameGlobals",
              "options/renameLabels",
              "options/movedDeclarations"
            ]
          },
          {
            "group": "Strings",
            "pages": [
              "options/stringConcealing",
              "options/customStringEncodings",
              "options/stringEncoding",
              "options/stringSplitting"
            ]
          },
          {
            "group": "Data",
            "pages": [
              "options/calculator",
              "options/objectExtraction",
              "options/globalConcealing",
              "options/duplicateLiteralsRemoval"
            ]
          },
          {
            "group": "Control-Flow",
            "pages": [
              "options/controlFlowFlattening",
              "options/dispatcher",
              "options/opaquePredicates",
              "options/deadCode",
              "options/astScrambler"
            ]
          },
          {
            "group": "Functions",
            "pages": [
              "options/variableMasking",
              "options/flatten",
              "options/rgf"
            ]
          },
          {
            "group": "Lock",
            "pages": [
              "options/domainLock",
              "options/startDate",
              "options/endDate",
              "options/tamperProtection",
              "options/selfDefending",
              "options/customLocks",
              "options/integrity",
              "options/antiDebug",
              "options/countermeasures"
            ]
          },
          {
            "group": "Output",
            "pages": [
              "options/hexadecimalNumbers",
              "options/compact",
              "options/minify",
              "options/preserveFunctionLength"
            ]
          }
        ]
      },
      {
        "group": "Presets",
        "pages": ["presets", "presets/high", "presets/medium", "presets/low"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "href": "https://js-confuser.com/editor",
        "label": "Try It Out"
      },
      {
        "href": "https://npmjs.com/package/js-confuser",
        "label": "NPM"
      },
      {
        "href": "https://github.com/MichaelXF/js-confuser",
        "label": "GitHub"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "toc"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/MichaelXF"
    }
  },
  "description": "JS-Confuser is an open-source JavaScript obfuscator. This obfuscation tool transforms your code into an unreadable, complex representation that is difficult to understand. Here you can learn everything you need to know about JS-Confuser.",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "grid"
  },
  "icons": {
    "library": "fontawesome"
  },
  "banner": {
    "content": "Still being worked on! Current documentation: https://js-confuser.com/docs",
    "dismissible": true
  }
}
