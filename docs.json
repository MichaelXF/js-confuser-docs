{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "JS-Confuser Docs",
  "colors": {
    "primary": "#3399ff",
    "light": "#3399ff",
    "dark": "#3399ff"
  },
  "favicon": {
    "light": "/images/apple-touch-icon.png",
    "dark": "/images/apple-touch-icon.png"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "what-is-obfuscation",
          "playground",
          "installation",
          "usage",
          "faq",
          "best-practices",
          "roadmap"
        ]
      },
      {
        "group": "Options",
        "pages": [
          "options/all-options",
          {
            "group": "Build Settings",
            "pages": [
              "options/target",
              "options/pack"
            ]
          },
          {
            "group": "Identifiers",
            "pages": [
              "identifier-generator",
              "rename-variables",
              "rename-globals",
              "untitled-page",
              "moved-declarations"
            ]
          }
        ]
      },
      {
        "group": "Presets",
        "pages": [
          "presets/all-presets",
          "presets/high",
          "presets/medium",
          "presets/low"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "href": "https://js-confuser.com/editor",
        "label": "Try It Out"
      },
      {
        "href": "https://github.com/MichaelXF/js-confuser",
        "label": "GitHub"
      },
      {
        "href": "https://npmjs.com/package/js-confuser",
        "label": "NPM"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "toc"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/MichaelXF"
    }
  },
  "description": "JS-Confuser is an open-source JavaScript obfuscator. This obfuscation tool transforms your code into an unreadable, complex representation that is difficult to understand. Here you can learn everything you need to know about JS-Confuser.",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient"
  },
  "icons": {
    "library": "fontawesome"
  },
  "banner": {
    "content": "This is not finished. Live documentation: https://js-confuser.com/docs",
    "dismissible": true
  }
}
